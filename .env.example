# Copy to .env and fill in. All values are server-side only (no VITE_ prefix),
# so nothing here is exposed to the browser.

# Database. Local dev can use a SQLite file: file:./local.db
# Production: your Turso URL (libsql://...turso.io) + a token from `turso db tokens create`.
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# The single admin account. There is no signup — only this account can sign in.
ADMIN_EMAIL="you@example.com"
# Generate with:  npm run hash-password -- "your-strong-password"
ADMIN_PASSWORD_HASH=""

# Random secret for signing the admin session cookie.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=""
